{
	"name": "@fairygitmother/server",
	"version": "0.1.0",
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsx watch src/index.ts",
		"start": "tsx src/index.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"@fairygitmother/core": "workspace:*",
		"better-sqlite3": "^11.0.0",
		"drizzle-orm": "^0.38.0",
		"pg": "^8.13.0",
		"hono": "^4.7.0",
		"octokit": "^4.1.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.0",
		"@types/pg": "^8.11.0",
		"drizzle-kit": "^0.30.0",
		"tsup": "^8.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0"
	}
}
